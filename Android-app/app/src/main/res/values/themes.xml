<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Aura" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.Aura.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FEFDFB</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Aura</item>
        <item name="windowSplashScreenIconBackgroundColor">#2E4376</item>
    </style>
</resources>
